    -- =========================================================
    -- [ LOGIKA BACKEND UNIVERSAL (DIJALANKAN DI BACKGROUND) ]
    -- =========================================================

    -- Player Movement Backend
    task.spawn(function()
        local WasWalkSpeed = false
        local WasFlying = false
        local movementConn = RunService.Stepped:Connect(function()
            if not _G.ScriptRunning then return end
            local char = LocalPlayer.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            
            if _G.NoclipToggle then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
                end
            end

            if _G.WalkSpeedToggle then
                if hum and not _G.FlyToggle then hum.WalkSpeed = _G.WalkSpeedValue; WasWalkSpeed = true end
            else
                if WasWalkSpeed and hum then hum.WalkSpeed = 16; WasWalkSpeed = false end
            end
            
            if _G.FlyToggle and hrp and hum then
                WasFlying = true
                hum.PlatformStand = true
                local flyAtt = hrp:FindFirstChild("LuvHubFlyAtt") or Instance.new("Attachment", hrp)
                flyAtt.Name = "LuvHubFlyAtt"
                local flyVel = hrp:FindFirstChild("LuvHubFlyVel") or Instance.new("LinearVelocity", hrp)
                flyVel.Name = "LuvHubFlyVel"; flyVel.Attachment0 = flyAtt; flyVel.MaxForce = math.huge; flyVel.RelativeTo = Enum.ActuatorRelativeTo.World
                local flyGyro = hrp:FindFirstChild("LuvHubFlyGyro") or Instance.new("AlignOrientation", hrp)
                flyGyro.Name = "LuvHubFlyGyro"; flyGyro.Mode = Enum.OrientationAlignmentMode.OneAttachment; flyGyro.Attachment0 = flyAtt; flyGyro.MaxTorque = math.huge; flyGyro.Responsiveness = 200
                
                local moveVector = Vector3.zero
                pcall(function() moveVector = require(LocalPlayer.PlayerScripts.PlayerModule):GetControls():GetMoveVector() end)
                local cam = workspace.CurrentCamera
                local flyDir = (cam.CFrame.LookVector * -moveVector.Z) + (cam.CFrame.RightVector * moveVector.X)
                local yDir = 0
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) or hum.Jump then yDir = yDir + 1 end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then yDir = yDir - 1 end
                flyDir = flyDir + Vector3.new(0, yDir, 0)
                if flyDir.Magnitude > 0 then flyDir = flyDir.Unit end
                
                flyVel.VectorVelocity = flyDir * _G.FlySpeedValue
                flyGyro.CFrame = CFrame.lookAt(Vector3.zero, cam.CFrame.LookVector)
            else
                if WasFlying and hum then
                    hum.PlatformStand = false; WasFlying = false
                    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end 
                end
                if hrp then
                    if hrp:FindFirstChild("LuvHubFlyAtt") then hrp.LuvHubFlyAtt:Destroy() end
                    if hrp:FindFirstChild("LuvHubFlyVel") then hrp.LuvHubFlyVel:Destroy() end
                    if hrp:FindFirstChild("LuvHubFlyGyro") then hrp.LuvHubFlyGyro:Destroy() end
                end
            end
        end)
        table.insert(_G.LuvHubConnections, movementConn)
    end)

    -- Anti-AFK Backend
    local afkConn = LocalPlayer.Idled:Connect(function()
        if _G.AntiAFK then
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                task.wait(0.2)
                VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            end)
        end
    end)
    table.insert(_G.LuvHubConnections, afkConn)

    -- Anti-Admin Backend
    local adminConn = Players.PlayerAdded:Connect(function(player)
        if not _G.AntiAdmin then return end
        local isStaff = false
        pcall(function()
            if game.CreatorType == Enum.CreatorType.Group and player:GetRankInGroup(game.CreatorId) > 0 then isStaff = true
            elseif game.CreatorType == Enum.CreatorType.User and player.UserId == game.CreatorId then isStaff = true end
        end)
        local n = string.lower(player.Name); local d = string.lower(player.DisplayName)
        for _, word in ipairs({"admin", "mod", "owner", "dev", "creator", "staff"}) do
            if string.find(n, word) or string.find(d, word) then isStaff = true; break end
        end
        if isStaff then
            LuvHubX:Notify({Title="⚠️ BAHAYA ADMIN", Text="Pindah server...", Duration=5})
            task.wait(3)
            pcall(function()
                local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
                local srvs = HttpService:JSONDecode(game:HttpGet(url))
                for _, srv in ipairs(srvs.data) do
                    if srv.playing < srv.maxPlayers and srv.id ~= game.JobId then
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, srv.id, LocalPlayer); return
                    end
                end
            end)
        end
    end)
    table.insert(_G.LuvHubConnections, adminConn)

    return Window
end

